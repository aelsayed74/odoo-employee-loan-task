<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_loan_summary_wizard_form" model="ir.ui.view">
    <field name="name">loan.summary.wizard.form</field>
    <field name="model">loan.summary.wizard</field>
    <field name="arch" type="xml">
        <form string="Excel Loan Summary Report">
            <group>
                <group string="Filter by Period">
                    <field name="date_from"/>
                    <field name="date_to"/>
                </group>
                <group string="Filter by Employee/Status">
                    <field name="employee_id" options="{'no_create': True}"/>
                    <field name="state"/>
                </group>
            </group>

            <footer>
                <button name="action_generate_excel" string="Export Excel" type="object" class="btn-primary"/>
                <button string="Cancel" class="btn-secondary" special="cancel"/>
            </footer>
        </form>
    </field>
</record>

    <record id="action_loan_summary_wizard" model="ir.actions.act_window">
        <field name="name">Excel Loan Summary</field>
        <field name="res_model">loan.summary.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_loan_report_excel" 
              name="Excel Summary Report" 
              parent="reports_menu" 
              action="action_loan_summary_wizard" 
              sequence="20"/>
</odoo>