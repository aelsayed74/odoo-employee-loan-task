<odoo>
    <record id="reject_loan_request_wizard_view_form" model="ir.ui.view">
        <field name="name">Reject Loan Request wizard view form</field>
        <field name="model">reject.loan.request</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="loan_id"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button string="Confirm" type="object" name="action_confirm" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form> 
        </field>
    </record>
</odoo>