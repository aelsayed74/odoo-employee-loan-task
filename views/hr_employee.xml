<odoo>
    <record id="inherit_hr_form_view" model="ir.ui.view">
        <field name="name">Inherit Hr Form</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
        <xpath expr="//div[@name='button_box']" position="inside">
            <button name="action_view_loan_requests" 
            type="object" 
            class="oe_stat_button" 
            icon="fa-money">
            <field name="loan_count" widget="statinfo" string="Loans"/>
            </button>
        </xpath>
        <xpath expr="//page[@name='hr_settings']" position="inside">
            <group>
                <field name="loan_account_id" string="Default Loan Account"/>
            </group>
        </xpath>
        </field>
    </record>
</odoo>