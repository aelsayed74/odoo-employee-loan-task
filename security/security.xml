<odoo>
    <record id="employee_loan_category" model="ir.module.category">
        <field name="name">Employee Loan</field>
    </record>
    <record id="employee_loan_manager_group" model="res.groups">
        <field name="name">Employee Loan Manager</field>
        <field name="category_id" ref="employee_loan_task.employee_loan_category"/>
    </record>
    <record id="employee_loan_user_group" model="res.groups">
        <field name="name">Employee Loan User</field>
        <field name="category_id" ref="employee_loan_request.employee_loan_category"/>
    </record>
    <!-- record rule -->
    <record id="employee_loan_record_rule_by_user" model="ir.rule">
        <field name="name">employee.loan.by.user</field>
        <field name="model_id" ref="model_employee_loan"/>
        <field name="domain_force">['|', ('create_uid', '=', user.id), ('create_uid', '=', False)]</field>
        <field name="groups" eval="[(4, ref('employee_loan_user_group'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>
    <record id="employee_loan_record_rule_by_manager" model="ir.rule">
        <field name="name">employee.loan.by.manager</field>
        <field name="model_id" ref="model_employee_loan"/>
        <field name="domain_force">[(1, '=', 1)]</field> 
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>